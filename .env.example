# ============================================================================
# DANAH Strategic Intelligence Platform — Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` at the repo root and fill in values.
# Lines marked [REQUIRED] must be set or the app fails fast at startup.
# Lines marked [SECRET] must never be committed or logged.
# ============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=DANAH
APP_ENV=development                # development | staging | production
APP_DEBUG=true                     # must be false in production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
TZ=Asia/Dubai

# Comma-separated allowed origins for the front end.
# "null" allows opening the v11 HTML file directly from disk during dev.
# REMOVE "null" and use exact https origins in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,null

# ---------------------------------------------------------------------------
# Security & Auth
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_64_random_chars_min          # [REQUIRED] [SECRET] e.g. `openssl rand -hex 48`
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Initial admin user created by scripts/seed.py (change password after first login)
ADMIN_EMAIL=admin@ministry.gov                        # [REQUIRED]
ADMIN_INITIAL_PASSWORD=CHANGE_ME_strong_password      # [REQUIRED] [SECRET]

# The first executive, i.e. the first person who can actually approve. Approval notifications are
# addressed to role=executive and nothing is ever published without an executive publishing it, so
# a deployment seeded with an admin alone has an approval queue nobody can clear or is told about.
# Seeded with ADMIN_INITIAL_PASSWORD — rotate it on first login.
APPROVER_EMAIL=executive@ministry.gov                 # [REQUIRED]

# Rate limits (per Redis sliding window)
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_CHAT_PER_MINUTE=20

# OIDC / Government SSO (Phase 4 — leave blank until then)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=                                   # [SECRET]

# ---------------------------------------------------------------------------
# Database — PostgreSQL 16 with pgvector extension
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://danah:danah@localhost:5432/danah   # [REQUIRED]
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Used by docker-compose to init the container (keep in sync with DATABASE_URL)
POSTGRES_USER=danah
POSTGRES_PASSWORD=danah                               # [SECRET] change outside local dev
POSTGRES_DB=danah

# Host ports docker-compose publishes. Change these (and the ports in DATABASE_URL /
# REDIS_URL to match) if another service already occupies 5432 / 6379 on your machine.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# ---------------------------------------------------------------------------
# Redis — cache, rate limiting, ARQ task queue
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0                    # [REQUIRED]

# ---------------------------------------------------------------------------
# LLM Providers (gateway picks by LLM_PROVIDER; fallback optional)
# ---------------------------------------------------------------------------
LLM_PROVIDER=anthropic                                # anthropic | openai
ANTHROPIC_API_KEY=                                    # [REQUIRED if provider=anthropic] [SECRET]
OPENAI_API_KEY=                                       # [REQUIRED if provider=openai or fallback enabled] [SECRET]
LLM_FALLBACK_ENABLED=false                            # if true, retry failed calls on the other provider

# Model tiers — primary for analysis/briefings, fast for triage/memory
LLM_MODEL_PRIMARY=claude-sonnet-4-5
LLM_MODEL_FAST=claude-haiku-4-5
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

LLM_MAX_TOKENS_DEFAULT=2048
LLM_TEMPERATURE_DEFAULT=0.2
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=3

# Cost guardrails
PIPELINE_TOKEN_BUDGET=400000            # hard cap per pipeline run (input+output tokens)
DAILY_COST_ALERT_USD=25                 # notification when exceeded

# Optional wholesale override of the built-in USD-per-1M-token price table
# (app/config.py DEFAULT_PRICE_TABLE). JSON object: model -> {input, output}.
# Leave blank to use the built-in table. Lets a price change ship without a deploy.
LLM_PRICE_TABLE=

# ---------------------------------------------------------------------------
# Embeddings (for RAG + memory)
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=voyage                             # voyage | openai
VOYAGE_API_KEY=                                       # [REQUIRED if provider=voyage] [SECRET]
EMBEDDING_MODEL=voyage-3.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1024                                    # MUST match the chosen model's output dimension
EMBEDDING_BATCH_SIZE=64

# ---------------------------------------------------------------------------
# RAG / Retrieval
# ---------------------------------------------------------------------------
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=150
RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.25                # cosine similarity floor
HYBRID_SEARCH_ENABLED=true              # vector + Postgres FTS fusion

# ---------------------------------------------------------------------------
# Agents & Orchestrator
# ---------------------------------------------------------------------------
AGENT_MAX_TOOL_ITERATIONS=6
SIGNAL_RELEVANCE_THRESHOLD=0.55         # items below this are archived, not analyzed
PIPELINE_SCHEDULE_CRON=0 5 * * *        # daily run at 05:00 (server TZ)
PIPELINE_MAX_ITEMS_PER_RUN=150
BRIEFING_LANGUAGES=en,ar

# ---------------------------------------------------------------------------
# Ingestion — open sources (no keys needed for these four)
# ---------------------------------------------------------------------------
WATCH_COUNTRIES=ARE,SAU,PAK,USA,CHN     # ISO3 codes for World Bank indicators
WORLDBANK_INDICATORS=NY.GDP.MKTP.KD.ZG,FP.CPI.TOTL.ZG,SL.UEM.TOTL.ZS
WATCH_QUERY_TERMS=trade policy,energy prices,supply chain,sanctions
RSS_FEEDS=https://feeds.bbci.co.uk/news/business/rss.xml,https://www.aljazeera.com/xml/rss/all.xml
RELIEFWEB_COUNTRY_FILTER=are,pak
DEFAULT_POLL_INTERVAL_MINUTES=60

# Webhook ingestion (future licensed feeds: Bloomberg, Reuters, FT)
WEBHOOK_HMAC_DEFAULT_SECRET=CHANGE_ME_shared_secret   # [SECRET] per-source override in DB
# NEWSAPI_KEY=                                        # optional future connector [SECRET]
# BLOOMBERG_API_CREDENTIALS=                          # placeholder until license procured [SECRET]
# REUTERS_API_CREDENTIALS=                            # placeholder until license procured [SECRET]

# ---------------------------------------------------------------------------
# File storage for uploaded documents
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local                   # local | s3
STORAGE_LOCAL_PATH=./data/documents
S3_ENDPOINT_URL=                        # e.g. sovereign MinIO endpoint
S3_BUCKET=danah-documents
S3_ACCESS_KEY_ID=                       # [SECRET]
S3_SECRET_ACCESS_KEY=                   # [SECRET]
S3_REGION=

MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,html

# ---------------------------------------------------------------------------
# Notifications (SMTP optional — unset = log-only mode)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=                          # [SECRET]
SMTP_FROM_EMAIL=danah-noreply@ministry.gov
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID
SENTRY_DSN=                             # optional error tracking [SECRET] — blank disables
